# Copy this file to `.env` for local development.
# On Vercel, add the same keys in Project Settings -> Environment Variables with production values.

# Public frontend config
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend app
APP_NAME=AgriFlow Backend
ENVIRONMENT=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agriflow

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
# Use a vision-capable model if you want image analysis in the soil assistant.
OLLAMA_MODEL=llava

# Geocoding
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Altitude
OPEN_ELEVATION_BASE_URL=https://api.open-elevation.com/api/v1
ALTITUDE_REQUIRED=false

# Climate model service
CLIMATE_MODEL_PATH=climate_model_v2.joblib

# General request settings
REQUEST_TIMEOUT_SECONDS=10.0
DEFAULT_FORECAST_HORIZON_MONTHS=3
DEFAULT_CURRENCY=MYR

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Vercel overrides
# NEXT_PUBLIC_API_BASE_URL=/server
# ENVIRONMENT=production
# OLLAMA_BASE_URL=https://ollama.com
# CORS_ORIGINS=["https://your-project.vercel.app","http://localhost:3000"]
