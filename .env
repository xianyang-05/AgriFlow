APP_NAME=AgriFlow Backend
ENVIRONMENT=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://postgres:mrWfHEqhjoGNZ5vY@db.wndbzoydgjgmnktpmuqg.supabase.co:5432/postgres

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Geocoding
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Altitude
OPEN_ELEVATION_BASE_URL=https://api.open-elevation.com/api/v1
